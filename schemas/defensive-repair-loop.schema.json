{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://example.org/schemas/defensive-repair-loop.schema.json",
"title": "Defensive Repair Loop",
"description": "A traceable defensive repair loop for converting abstract risk observations into verified repair actions, review gates, and audit records.",
"type": "object",
"additionalProperties": false,
"required": [
"schema_version",
"loop_id",
"created_at",
"source",
"trigger",
"loop_policy",
"stages",
"repair_outputs",
"trace_receipt",
"human_review"
],
"properties": {
"schema_version": {
"type": "string",
"const": "0.2.0"
},
"loop_id": {
"type": "string",
"description": "Unique identifier for this defensive repair loop.",
"pattern": "^repair-loop-[a-zA-Z0-9.*-]+$"
},
"created_at": {
"type": "string",
"format": "date-time"
},
"source": {
"type": "object",
"additionalProperties": false,
"required": [
"source_type",
"source_id",
"description"
],
"properties": {
"source_type": {
"type": "string",
"enum": [
"mythos_regulation_record",
"security_review",
"agent_design_review",
"workflow_review",
"system_prompt_review",
"manual_observation",
"other"
]
},
"source_id": {
"type": "string",
"minLength": 1
},
"description": {
"type": "string",
"minLength": 1
}
}
},
"trigger": {
"type": "object",
"additionalProperties": false,
"required": [
"reason",
"risk_summary",
"initial_risk_level"
],
"properties": {
"reason": {
"type": "string",
"minLength": 1
},
"risk_summary": {
"type": "string",
"minLength": 1
},
"initial_risk_level": {
"type": "string",
"enum": [
"low",
"medium",
"high",
"critical"
]
},
"affected_boundaries": {
"type": "array",
"items": {
"type": "string"
},
"default": []
}
}
},
"loop_policy": {
"type": "object",
"description": "Rules that constrain the loop to defensive repair and traceable review.",
"additionalProperties": false,
"required": [
"offensive_detail_expansion",
"repair_first",
"trace_required",
"human_review_for_deployment",
"allowed_environment"
],
"properties": {
"offensive_detail_expansion": {
"type": "string",
"enum": [
"not_allowed",
"abstract_only"
]
},
"repair_first": {
"type": "boolean",
"const": true
},
"trace_required": {
"type": "boolean",
"const": true
},
"human_review_for_deployment": {
"type": "boolean",
"const": true
},
"allowed_environment": {
"type": "string",
"enum": [
"documentation_only",
"local_test_environment",
"authorized_staging_environment",
"authorized_production_with_review"
]
},
"notes": {
"type": "string"
}
}
},
"stages": {
"type": "object",
"additionalProperties": false,
"required": [
"observe",
"analyze",
"repair",
"verify",
"record",
"review"
],
"properties": {
"observe": {
"$ref": "#/$defs/stage"
},
"analyze": {
"$ref": "#/$defs/stage"
},
"repair": {
"$ref": "#/$defs/stage"
},
"verify": {
"$ref": "#/$defs/stage"
},
"record": {
"$ref": "#/$defs/stage"
},
"review": {
"$ref": "#/$defs/stage"
}
}
},
"repair_outputs": {
"type": "array",
"description": "Concrete defensive outputs produced by the loop.",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"output_id",
"output_type",
"summary",
"priority",
"verification_required"
],
"properties": {
"output_id": {
"type": "string",
"pattern": "^repair-output-[a-zA-Z0-9.*-]+$"
},
"output_type": {
"type": "string",
"enum": [
"policy_change",
"permission_boundary",
"stop_condition",
"logging_requirement",
"trace_requirement",
"configuration_change",
"documentation_update",
"test_case",
"human_review_gate",
"other"
]
},
"summary": {
"type": "string",
"minLength": 1
},
"priority": {
"type": "string",
"enum": [
"low",
"medium",
"high",
"critical"
]
},
"minimum_change": {
"type": "boolean",
"description": "Whether this output is designed as a minimum viable defensive change."
},
"verification_required": {
"type": "boolean"
}
}
}
},
"trace_receipt": {
"type": "object",
"description": "Trace record for the full repair loop.",
"additionalProperties": false,
"required": [
"origin_question",
"loop_summary",
"stage_order",
"transformation",
"residual_risks",
"final_status"
],
"properties": {
"origin_question": {
"type": "string",
"minLength": 1
},
"loop_summary": {
"type": "string",
"minLength": 1
},
"stage_order": {
"type": "array",
"minItems": 6,
"items": {
"type": "string",
"enum": [
"observe",
"analyze",
"repair",
"verify",
"record",
"review"
]
}
},
"transformation": {
"type": "string",
"minLength": 1
},
"residual_risks": {
"type": "array",
"items": {
"type": "string"
},
"default": []
},
"final_status": {
"type": "string",
"enum": [
"drafted",
"ready_for_review",
"review_required",
"verified_in_test",
"deployed_with_review",
"blocked"
]
}
}
},
"human_review": {
"type": "object",
"additionalProperties": false,
"required": [
"required",
"review_gate",
"reason"
],
"properties": {
"required": {
"type": "boolean",
"const": true
},
"review_gate": {
"type": "string",
"enum": [
"before_deployment",
"before_permission_expansion",
"before_high_impact_action",
"before_external_testing",
"before_policy_change",
"always"
]
},
"reason": {
"type": "string",
"minLength": 1
},
"reviewer_role": {
"type": "string",
"description": "Suggested reviewer role, such as maintainer, security reviewer, or system owner."
}
}
}
},
"$defs": {
"stage": {
"type": "object",
"additionalProperties": false,
"required": [
"purpose",
"inputs",
"actions",
"outputs",
"status"
],
"properties": {
"purpose": {
"type": "string",
"minLength": 1
},
"inputs": {
"type": "array",
"items": {
"type": "string"
},
"default": []
},
"actions": {
"type": "array",
"minItems": 1,
"items": {
"type": "string"
}
},
"outputs": {
"type": "array",
"items": {
"type": "string"
},
"default": []
},
"status": {
"type": "string",
"enum": [
"pending",
"in_progress",
"completed",
"blocked",
"requires_review"
]
},
"notes": {
"type": "string"
}
}
}
}
}
