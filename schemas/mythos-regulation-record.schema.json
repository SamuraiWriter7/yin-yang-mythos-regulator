{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/mythos-regulation-record.schema.json",
  "title": "Mythos Regulation Record",
  "description": "A record for converting offensive or expansive AI tendencies into defensive repair, boundary preservation, and traceable regulation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "created_at",
    "target",
    "original_tendency",
    "regulation_shift",
    "yang_wing_observation",
    "yin_wing_repair",
    "safeguards",
    "trace_receipt",
    "human_review"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "record_id": {
      "type": "string",
      "description": "Unique identifier for this regulation record.",
      "pattern": "^mythos-reg-[a-zA-Z0-9._-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "name",
        "description"
      ],
      "properties": {
        "target_type": {
          "type": "string",
          "enum": [
            "large_model_output",
            "agent_design",
            "workflow",
            "system_prompt",
            "tool_permission_model",
            "security_review",
            "other"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "owner_or_context": {
          "type": "string",
          "description": "Optional owner, project, repository, or operational context."
        }
      }
    },
    "original_tendency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "risk_level",
        "summary"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "offensive",
            "expansive",
            "exploit_seeking",
            "over_autonomous",
            "ambiguous",
            "other"
          ]
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "observed_signals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "regulation_shift": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "purpose"
      ],
      "properties": {
        "from": {
          "type": "string",
          "description": "Original center of gravity, such as exploitation, expansion, or domination."
        },
        "to": {
          "type": "string",
          "description": "Defensive center of gravity, such as repair, boundary preservation, or traceability."
        },
        "purpose": {
          "type": "string",
          "description": "Why this regulation shift is required."
        }
      }
    },
    "yang_wing_observation": {
      "type": "object",
      "description": "Abstract vulnerability observation. This section must not include exploit execution steps or harmful payloads.",
      "additionalProperties": false,
      "required": [
        "role",
        "allowed_scope",
        "observations"
      ],
      "properties": {
        "role": {
          "type": "string",
          "const": "abstract_vulnerability_observation"
        },
        "allowed_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "premise_review",
              "boundary_review",
              "permission_review",
              "logging_gap_review",
              "misuse_path_abstraction",
              "failure_mode_mapping",
              "defensive_risk_identification"
            ]
          }
        },
        "observations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "observation_id",
              "category",
              "summary",
              "defensive_relevance"
            ],
            "properties": {
              "observation_id": {
                "type": "string",
                "pattern": "^obs-[a-zA-Z0-9._-]+$"
              },
              "category": {
                "type": "string",
                "enum": [
                  "premise_risk",
                  "boundary_gap",
                  "permission_excess",
                  "trace_gap",
                  "stop_condition_gap",
                  "misuse_potential",
                  "repair_priority",
                  "other"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "defensive_relevance": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "yin_wing_repair": {
      "type": "object",
      "description": "Defensive repair and boundary preservation plan.",
      "additionalProperties": false,
      "required": [
        "role",
        "repair_strategy",
        "boundary_preservation",
        "verification"
      ],
      "properties": {
        "role": {
          "type": "string",
          "const": "defensive_repair_and_boundary_preservation"
        },
        "repair_strategy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "repair_id",
              "action",
              "priority"
            ],
            "properties": {
              "repair_id": {
                "type": "string",
                "pattern": "^repair-[a-zA-Z0-9._-]+$"
              },
              "action": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              },
              "minimum_change": {
                "type": "boolean",
                "description": "Whether this repair is designed as a minimum viable defensive change."
              }
            }
          }
        },
        "boundary_preservation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "safeguards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prohibited_outputs",
        "required_constraints"
      ],
      "properties": {
        "prohibited_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "exploit_execution_steps",
              "unauthorized_intrusion_guidance",
              "malicious_code",
              "credential_theft",
              "persistence_or_evasion",
              "harmful_payloads",
              "real_target_attack_instructions"
            ]
          }
        },
        "required_constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "repair_first_framing",
              "abstract_risk_only",
              "trace_required",
              "human_review_required",
              "least_privilege",
              "no_unauthorized_testing",
              "defensive_verification_only"
            ]
          }
        }
      }
    },
    "trace_receipt": {
      "type": "object",
      "description": "Trace record for the regulation shift.",
      "additionalProperties": false,
      "required": [
        "origin_question",
        "premises",
        "transformation",
        "uncertainty",
        "final_shift"
      ],
      "properties": {
        "origin_question": {
          "type": "string",
          "minLength": 1
        },
        "premises": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "transformation": {
          "type": "string",
          "description": "How the output was shifted from offensive tendency to defensive repair."
        },
        "uncertainty": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "final_shift": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "reason"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "reviewer_role": {
          "type": "string",
          "description": "Suggested reviewer role, such as maintainer, security reviewer, or system owner."
        }
      }
    }
  }
}
